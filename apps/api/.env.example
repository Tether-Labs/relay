PORT=3847
API_URL=http://localhost:3847
WEB_URL=http://localhost:5173
# Comma-separated extra browser origins allowed to call /api and /auth.
CORS_ORIGINS=
# Set when API and web share a parent domain, e.g. .relay.so
COOKIE_DOMAIN=
DATABASE_URL=./data/relay.db
STORAGE_DIR=./storage
SESSION_SECRET=change-me-in-production
RELAY_HIDE_FOOTER=0

# --- Email (Resend) ---
# Get a key at https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxx
EMAIL_FROM=Relay <noreply@tether-labs.com>
RESEND_TEST_TO=naren.sathiya@tether-labs.com

# Log magic links to terminal (default: on when RESEND_API_KEY is empty, off when set)
# Set LOG_MAGIC_LINKS=1 to also log links when Resend sends (handy while debugging)
# LOG_MAGIC_LINKS=1
