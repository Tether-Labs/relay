# Copy to .env.production for production deploys (`npm run sync:fly-secrets`, Fly reference)
# Use sk_live_... from Clerk. Fly stores these as secrets — this file is your local source of truth.

PORT=3847
API_URL=https://relay-tether-labs.fly.dev
WEB_URL=https://relay.tether-labs.com
CORS_ORIGINS=https://relay.tether-labs.com
COOKIE_DOMAIN=
DATABASE_URL=/data/relay.db
STORAGE_DIR=/data/storage
SESSION_SECRET=replace-with-openssl-rand-hex-32
RELAY_HIDE_FOOTER=0
CLERK_SECRET_KEY=sk_live_xxx
EMAIL_FROM=Relay <noreply@tether-labs.com>
RESEND_API_KEY=re_xxxxxxxxx
LOG_MAGIC_LINKS=0
